# =============================================================================
# perpetual-scholar-agent — .env.example
# Copy this file to .env and fill in your values. Never commit .env to git.
# =============================================================================

# ── General ──────────────────────────────────────────────────────────────────
DOMAIN_FOCUS="backend performance optimization: database sharding, caching strategies, async I/O patterns, clean architecture"
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
DATA_DIR=./data                         # SQLite + FAISS index directory
MODELS_DIR=./models                     # LoRA adapters + RL policy checkpoints

# ── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama                     # ollama | claude | openai
LLM_FALLBACK_CHAIN=ollama,claude,openai # comma-separated fallback order

# ── Ollama (local SLM) ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# ── Anthropic Claude API (optional) ──────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── OpenAI GPT API (optional) ────────────────────────────────────────────────
OPENAI_API_KEY=
GPT_MODEL=gpt-4o

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── arXiv ─────────────────────────────────────────────────────────────────────
ARXIV_CATEGORIES=cs.DB,cs.DC,cs.PF       # comma-separated arXiv categories
ARXIV_MAX_RESULTS=50                     # max papers per daily fetch

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=                            # personal access token (optional, avoids rate limits)
GITHUB_TRENDING_LANGUAGES=python,go      # comma-separated languages for trending repos
GITHUB_TRENDING_SINCE=daily              # daily | weekly | monthly

# ── RSS Feeds ─────────────────────────────────────────────────────────────────
RSS_FEEDS=https://medium.com/feed/engineering,https://hnrss.org/frontpage

# ── Docker Sandbox ────────────────────────────────────────────────────────────
SANDBOX_DOCKER_IMAGE=psa-sandbox:latest  # built from docker/sandbox.Dockerfile
SANDBOX_CPU_LIMIT=2                      # CPU cores
SANDBOX_MEMORY_LIMIT=2g                  # RAM limit
SANDBOX_TIMEOUT_SECONDS=60               # execution timeout
SANDBOX_NETWORK_DISABLED=true            # --network=none for security

# ── Benchmark ─────────────────────────────────────────────────────────────────
BENCHMARK_WARMUP_ITERATIONS=5
BENCHMARK_MEASURE_ITERATIONS=30
BENCHMARK_TIMEOUT_SECONDS=30

# ── RL / PPO ──────────────────────────────────────────────────────────────────
RL_LEARNING_RATE=3e-4
RL_GAMMA=0.99
RL_CLIP_RANGE=0.2
RL_N_STEPS=128
RL_BATCH_SIZE=64
RL_N_EPOCHS=10

# ── LoRA Fine-tuning ──────────────────────────────────────────────────────────
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
LORA_TARGET_MODULES=q_proj,v_proj
LORA_TRAINING_EPOCHS=3
LORA_LEARNING_RATE=2e-4
LORA_TRIGGER_LESSON_COUNT=50            # auto-finetune after N new verified lessons
LORA_TRIGGER_DAYS=7                     # auto-finetune after N days since last run
LORA_MAX_SEQ_LENGTH=2048

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULE_INGESTION_CRON=0 2 * * *       # daily at 02:00 UTC
SCHEDULE_FINETUNE_CRON=0 3 * * 0       # weekly Sunday 03:00 UTC
SCHEDULE_BRAIN_UPDATE_CRON=0 6 * * 0    # weekly Sunday 06:00 UTC
SCHEDULE_REPORT_CRON=0 8 * * 1          # weekly Monday 08:00 UTC

# ── Reward ────────────────────────────────────────────────────────────────────
REWARD_IMPROVEMENT_THRESHOLD=0.05       # >5% improvement → positive reward
REWARD_DEGRADATION_THRESHOLD=-0.05      # >5% degradation → negative reward
REWARD_LLM_JUDGE_WEIGHT=0.3            # weight for LLM judge in combined reward
REWARD_BENCHMARK_WEIGHT=0.7             # weight for benchmark in combined reward

# ── Monitoring ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
FASTAPI_DASHBOARD_HOST=0.0.0.0
FASTAPI_DASHBOARD_PORT=8080

# ── Redis (optional task queue) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false
